{
  "name": "clio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,api -c blue,green \"vite\" \"npm run dev:server\"",
    "dev:server": "PORT=3001 CLIO_DATA_DIR=./data node --watch server/index.js",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/uuid": "^10.0.0",
    "idb-keyval": "^6.2.2",
    "katex": "^0.16.47",
    "pdfjs-dist": "5.4.296",
    "perfect-freehand": "^1.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^7.0.1",
    "react-pdf": "^10.4.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "uuid": "^14.0.0",
    "webdav": "^5.10.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
